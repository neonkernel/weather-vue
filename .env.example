# ============================================================
# Summarizer CLI - Environment Variables Template
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ============================================================

# Required: Your OpenAI API key
# Get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Optional: The OpenAI model to use for summarization
# Default: gpt-4o-mini
SUMMARIZER_MODEL=gpt-4o-mini

# Optional: Maximum number of tokens in the summary response
# Default: 512
SUMMARIZER_MAX_TOKENS=512

# Optional: HTTP request timeout in seconds when fetching URLs
# Default: 30
SUMMARIZER_TIMEOUT=30