# ==============================================================================
# Summarizer CLI - Environment Variables Template
# ==============================================================================
# Copy this file to .env and fill in your actual values.
# Never commit the .env file to version control.

# ------------------------------------------------------------------------------
# OpenAI API Configuration (Required)
# ------------------------------------------------------------------------------

# Your OpenAI API key (get one at https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-your-api-key-here

# ------------------------------------------------------------------------------
# Model Configuration (Optional)
# ------------------------------------------------------------------------------

# The OpenAI model to use for summarization
# Options: gpt-4o, gpt-4o-mini, gpt-4-turbo, gpt-3.5-turbo
# Default: gpt-4o-mini
SUMMARIZER_MODEL=gpt-4o-mini

# Maximum number of tokens to generate in the summary
# Default: 512
SUMMARIZER_MAX_TOKENS=512

# Sampling temperature (0.0 = deterministic, 1.0 = creative)
# Default: 0.3
SUMMARIZER_TEMPERATURE=0.3

# ------------------------------------------------------------------------------
# Request Configuration (Optional)
# ------------------------------------------------------------------------------

# Timeout in seconds for HTTP requests when fetching URLs
# Default: 30
SUMMARIZER_REQUEST_TIMEOUT=30