# ==============================================================================
# Summarizer CLI - Environment Configuration
# ==============================================================================
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ------------------------------------------------------------------------------
# OpenAI API Configuration (Required)
# ------------------------------------------------------------------------------

# Your OpenAI API key (required for summarization)
OPENAI_API_KEY=sk-...

# ------------------------------------------------------------------------------
# Model Configuration (Optional)
# ------------------------------------------------------------------------------

# The OpenAI model to use for summarization
# Recommended: gpt-4o-mini (fast & cheap), gpt-4o (best quality)
SUMMARIZER_MODEL=gpt-4o-mini

# Maximum number of tokens to generate in the summary
SUMMARIZER_MAX_TOKENS=512

# Sampling temperature (0.0 = deterministic, 1.0 = creative)
SUMMARIZER_TEMPERATURE=0.3