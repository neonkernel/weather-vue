# ============================================================
# Summarizer Environment Variables
# Copy this file to .env and fill in the values.
# ============================================================

# Required: Your OpenAI API key
OPENAI_API_KEY=sk-...

# Optional: Model to use for summarization
# Default: gpt-4o-mini
SUMMARIZER_MODEL=gpt-4o-mini

# Optional: Maximum number of tokens in the generated summary
# Default: 512
SUMMARIZER_MAX_TOKENS=512

# Optional: Default summary style (paragraph | bullet | tldr)
# Default: paragraph
SUMMARIZER_DEFAULT_STYLE=paragraph

# Optional: Default output format (plain | markdown | json)
# Default: plain
SUMMARIZER_DEFAULT_FORMAT=plain