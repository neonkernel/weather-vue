# ==============================================================================
# Summarizer CLI - Environment Variables
# ==============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ==============================================================================

# ------------------------------------------------------------------------------
# OpenAI Configuration (required for AI summarization)
# ------------------------------------------------------------------------------

# Your OpenAI API key (get one at https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-...

# OpenAI model to use for summarization
# Options: gpt-4o, gpt-4o-mini, gpt-4-turbo, gpt-3.5-turbo
SUMMARIZER_MODEL=gpt-4o-mini

# Maximum number of tokens in the generated summary
MAX_TOKENS=512

# ------------------------------------------------------------------------------
# Logging Configuration
# ------------------------------------------------------------------------------

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO