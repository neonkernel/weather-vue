# OpenAI API Configuration
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Model Configuration
# Recommended models: gpt-4o-mini, gpt-4o, gpt-3.5-turbo
SUMMARIZER_MODEL=gpt-4o-mini

# Maximum number of tokens to generate in the summary
SUMMARIZER_MAX_TOKENS=1024

# Model temperature (0.0 = deterministic, 2.0 = very creative)
SUMMARIZER_TEMPERATURE=0.7